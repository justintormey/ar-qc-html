#!/usr/bin/env bash
# Local deploy for ar-qc-html -> S3 + CloudFront.
# Replaces the archived half-bakery deployer (retired 2026-05-25).
#
# Usage:
#   ./scripts/deploy --dry-run    # preview changes
#   ./scripts/deploy              # apply

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$SCRIPT_DIR/.."
SOURCE_DIR="$REPO_DIR/dist"
DEPLOY_CONFIG="$REPO_DIR/.local/deploy.json"
S3_PATH="s3://justintormey.com/ar-qc"
CF_INVALIDATION_PATH="/ar-qc/*"

if [ ! -f "$DEPLOY_CONFIG" ]; then
  echo "ERROR: deploy config missing: $DEPLOY_CONFIG" >&2
  exit 1
fi
AWS_PROFILE=$(/usr/bin/python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['aws_profile'])" "$DEPLOY_CONFIG")
CF_ID=$(/usr/bin/python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['cloudfront_id'])" "$DEPLOY_CONFIG")

DRY_RUN=""
if [ "${1:-}" = "--dry-run" ]; then
  DRY_RUN="--dryrun"
  echo "-- DRY RUN --"
fi

echo "Building..."
( cd "$REPO_DIR" && npm run build )

echo "Source : $SOURCE_DIR"
echo "Target : $S3_PATH"
echo "Profile: $AWS_PROFILE"
echo "CloudFront: $CF_ID ($CF_INVALIDATION_PATH)"
echo

aws s3 sync "$SOURCE_DIR/" "$S3_PATH/" \
  --profile "$AWS_PROFILE" \
  --delete \
  --exclude "*.pyc" \
  --exclude "*.pyc/*" \
  --exclude ".DS_Store" \
  --exclude ".DS_Store/*" \
  --exclude ".agent" \
  --exclude ".agent/*" \
  --exclude ".git" \
  --exclude ".git/*" \
  --exclude ".gitattributes" \
  --exclude ".gitattributes/*" \
  --exclude ".github" \
  --exclude ".github/*" \
  --exclude ".gitignore" \
  --exclude ".gitignore/*" \
  --exclude ".local" \
  --exclude ".local/*" \
  --exclude "AGENTS.md" \
  --exclude "AGENTS.md/*" \
  --exclude "CHANGELOG.md" \
  --exclude "CHANGELOG.md/*" \
  --exclude "CLAUDE.md" \
  --exclude "CLAUDE.md/*" \
  --exclude "README.md" \
  --exclude "README.md/*" \
  --exclude "__pycache__" \
  --exclude "__pycache__/*" \
  --exclude "docs" \
  --exclude "docs/*" \
  --exclude "history.md" \
  --exclude "history.md/*" \
  --exclude "node_modules" \
  --exclude "node_modules/*" \
  --exclude "package-lock.json" \
  --exclude "package-lock.json/*" \
  --exclude "package.json" \
  --exclude "package.json/*" \
  --exclude "scripts" \
  --exclude "scripts/*" \
  --exclude "tests" \
  --exclude "tests/*" \
  $DRY_RUN

if [ -n "$DRY_RUN" ]; then
  echo
  echo "DRY RUN -- re-run without --dry-run to apply."
  exit 0
fi

echo
echo "Creating CloudFront invalidation..."
aws cloudfront create-invalidation \
  --distribution-id "$CF_ID" \
  --paths "$CF_INVALIDATION_PATH" \
  --profile "$AWS_PROFILE" \
  --output text --query 'Invalidation.{Id:Id,Status:Status}'

echo "Done."
